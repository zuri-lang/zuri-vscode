{
    "name": "zuri-vscode",
    "displayName": "zuri-vscode",
    "description": "Support for the Zuri programming language",
    "publisher": "zuri-lang",
    "author": "Ore Richard Muyiwa",
    "version": "0.1.0",
    "homepage": "https://github.com/zuri-lang/zuri-vscode",
    "repository": {
        "type": "git",
        "url": "https://github.com/zuri-lang/zuri-vscode.git"
    },
    "icon": "img/icon.png",
    "engines": {
        "vscode": "^1.58.0"
    },
    "categories": [
        "Themes",
        "Programming Languages",
        "Snippets"
    ],
    "main": "./extension.js",
    "activationEvents": [
        "onLanguage:zuri",
        "onDebugResolve:zuri",
        "onCommand:zuri.checkZuriInstalled"
    ],
    "contributes": {
        "themes": [
            {
                "label": "Zuri",
                "uiTheme": "vs-dark",
                "path": "./themes/zuri-color-theme.json"
            }
        ],
        "languages": [
            {
                "id": "zuri",
                "aliases": [
                    "Zuri",
                    "zuri"
                ],
                "extensions": [
                    ".zu"
                ],
                "configuration": "./language/zuri-configuration.json",
                "icon": {
                    "light": "./img/icon.png",
                    "dark": "./img/icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "zuri",
                "scopeName": "source.zuri",
                "path": "./language/syntaxes/zuri.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "zuri.checkZuriInstalled",
                "title": "Check Zuri Installation",
                "category": "Zuri"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "zuri.checkZuriInstalled",
                    "when": "editorLangId == zuri"
                }
            ]
        },
        "snippets": [
            {
                "language": "zuri",
                "path": "./snippets/snippets.json"
            }
        ]
    },
    "dependencies": {
        "command-exists-promise": "^2.0.2"
    }
}